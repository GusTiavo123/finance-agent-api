# --- Required: set your own values ---------------------------------------
# API keys accepted by the service (comma-separated for multiple clients).
# Every request must send one of these in the `X-API-Key` header.
# Each key gets its own isolated conversation space and rate-limit budget.
API_KEYS=change-me

# Claude model used by the agent (claude-haiku-4-5 is fast and cost-effective;
# claude-sonnet-4-6 gives richer analysis) plus your Anthropic API key.
LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-...

# --- Docker Compose wiring (already correct for `docker compose up`) ------
REDIS_URL=redis://redis:6379/0
TELEMETRY_BACKENDS=log,file
TELEMETRY_FILE=/data/governance/governance.jsonl

# --- Optional (sensible defaults) ----------------------------------------
# STORAGE_BACKEND=redis              # redis | memory (memory = single process, no persistence)
# CONVERSATION_TTL_SECONDS=604800    # conversations expire after 7 days
# RATE_LIMIT_REQUESTS=10             # requests allowed per API key per window
# RATE_LIMIT_WINDOW_SECONDS=60
# MAX_AGENT_ITERATIONS=5             # max LLM<->tools round trips per message
# HISTORY_WINDOW_MESSAGES=20         # messages from history sent to the LLM
# LLM_TIMEOUT_SECONDS=60
# LOG_LEVEL=INFO
